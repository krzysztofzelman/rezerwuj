# === APLIKACJA ===
DATABASE_URL=sqlite:///./rezerwuj.db
SECRET_KEY=zmien-na-losowy-klucz-minimum-32-znaki
JWT_ALGORITHM=HS256
SITE_URL=http://localhost:8000

# === STRIPE (płatności i subskrypcje) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUBSCRIPTION_PRICE_ID=price_...  # ID produktu Stripe dla subskrypcji miesięcznej
SUBSCRIPTION_PRICE_PLN=7900       # 79,00 PLN w groszach

# === SMS (SMSAPI.pl lub Twilio) ===
SMS_API_KEY=
SMS_SENDER=Rezerwuj
SMS_MOCK=true  # true = loguje SMS do konsoli, false = wysyła przez API

# === KONFIGURACJA ===
TRIAL_DAYS=14
MAX_BOOKING_DAYS_AHEAD=60
