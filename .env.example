# === APLIKACJA ===
DATABASE_URL=sqlite:///./napraw_mnie.db
SECRET_KEY=zmien-na-losowy-klucz-minimum-32-znaki
JWT_ALGORITHM=HS256
SITE_URL=http://localhost:8000
ADMIN_EMAIL=admin@naprawmnie.pl
ADMIN_PASSWORD=Admin123!

# === STRIPE (płatności i subskrypcje) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUBSCRIPTION_PRICE_ID=price_...  # ID produktu Stripe dla subskrypcji miesięcznej
SUBSCRIPTION_PRICE_PLN=7900       # 79,00 PLN w groszach

# === SMS (SMSAPI.pl lub Twilio) ===
SMS_API_KEY=
SMS_SENDER=NaprawMnie
SMS_MOCK=true  # true = loguje SMS do konsoli, false = wysyła przez API

# === E-MAIL (SMTP) ===
# Używa STARTTLS na porcie 587. Przy EMAIL_MOCK=true loguje do konsoli.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@naprawmnie.pl
SMTP_PASSWORD=twoje-haslo-smtp
SMTP_FROM=Napraw Mnie <noreply@naprawmnie.pl>
EMAIL_MOCK=true  # true = loguje e-mail do konsoli, false = wysyła przez SMTP

# === reCAPTCHA v2 (Checkbox) ===
RECAPTCHA_SITE_KEY=6Ld...  # Site key z Google reCAPTCHA Admin
RECAPTCHA_SECRET_KEY=6Ld...  # Secret key z Google reCAPTCHA Admin

# === Redis (rate limiting) ===
# Gdy puste — używa pamięci RAM. W produkcji z Redis znacząco poprawia skalowanie.
REDIS_URL=redis://localhost:6379/0

# === KONFIGURACJA ===
TRIAL_DAYS=14
MAX_BOOKING_DAYS_AHEAD=60
